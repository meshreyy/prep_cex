DATABASE_URL=postgresql://...
ENGINE_TRANSPORT=http
ENGINE_HTTP_URL=http://localhost:3001
JWT_SECRET=your-secret
INCOMING_QUEUE=stream:commands
RESPONSE_QUEUE=stream:responses
PORT=3000

# Comma-separated frontend origins (Vercel URL). Use * to allow all (not recommended for production).
CORS_ORIGIN=http://localhost:5173,https://your-app.vercel.app
