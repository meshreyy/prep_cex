REDIS_URL=redis://localhost:6379
INCOMING_QUEUE=stream:commands
RESPONSE_QUEUE=stream:responses
EVENTS_QUEUE=stream:events

# Simulation worker — keeps orderbook + trade tape alive
SIMULATION_ENABLED=true
SIMULATION_INTERVAL_MS=2000
SIMULATION_MARKETS=BTC-PERP,ETH-PERP
SIMULATION_TICK_SIZE=10
SIMULATION_LEVELS=20
SIMULATION_QTY_MIN=0.005
SIMULATION_QTY_MAX=0.05
SIMULATION_ORDERS_PER_LEVEL=2
SIMULATION_TAKER_PROB=0.55
SIMULATION_NOISE_PROB=0.15
